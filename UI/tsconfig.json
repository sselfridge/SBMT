{
  "compilerOptions": {
    // Compilation target & libs
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    // JSX — react-jsx uses the automatic transform (React 17+, no import needed)
    "jsx": "react-jsx",

    "module": "ESNext",
    "moduleResolution": "bundler",

    // Path aliases
    // `baseUrl: "src"` preserves existing bare imports (e.g. import AppContext from "AppContext")
    // `paths` adds the @ alias — paths are relative to baseUrl
    "baseUrl": "src",
    "paths": {
      "@/*": ["./*"]
    },

    // Incremental JS→TS migration: allow .js files alongside .ts
    "allowJs": true,
    "checkJs": false,

    // Strict mode — enforced for all new .ts/.tsx files
    "strict": true,

    // Vite handles emit; tsc is type-check only
    "noEmit": true,

    // Interop & safety
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
